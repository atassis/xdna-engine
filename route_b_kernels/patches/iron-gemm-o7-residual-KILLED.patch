@@ -409,6 +409,25 @@ matmul_vectorized_8x8x8_i8_i32(const int8 *__restrict pA, const int8 *__restrict
         pA, pB, pC);
 }
 
+// O7 epilogue fusion: preload the GEMM C accumulation buffer with the residual
+// tensor instead of zeroing it, so the subsequent matmul K-loop accumulates
+// W@x ONTO the residual (C = residual + W@x). Fuses the per-layer residual-add
+// into the projection at zero extra compute. `resid` has the same flat [M*N]
+// layout as C's accumulation buffer (col-maj [N,M] when c_col_maj), so the copy
+// is layout-agnostic. Mirrors zero_vectorized's linear store pattern.
+template <typename T, int M, int N>
+void preload_residual_vectorized(T *__restrict c, const T *__restrict resid)
+{
+    constexpr int r = 512 / (sizeof(T) * 8); // 512-bit units (AIE2P)
+    static_assert((M * N) % r == 0);
+    const T *__restrict c_end = c + M * N;
+    event0();
+    for (; c < c_end; c += r, resid += r) {
+        aie::store_v(c, aie::load_v<r>(resid));
+    }
+    event1();
+}
+
 extern "C" {
 
 // If you want to compile microkernels with different inner tile sizes,
@@ -507,6 +526,14 @@ extern "C" {
         zero_scalar<ctype_out, DIM_M, DIM_N>(c_out);                                                                   \
     }
 
-combos(matmul_vectorized_c_func) combos(matmul_scalar_c_func) combos(zero_vectorized_c_func) combos(zero_scalar_c_func)
+// O7: preload-C (residual fusion) — replaces zero_##type when a GEMM fuses its
+// following residual-add. Signature mirrors zero_ but takes the residual input.
+#define preload_residual_c_func(ctype_in, mlir_type_in, ctype_out, mlir_type_out, r, s, t)                             \
+    void preload_residual_##mlir_type_out(ctype_out *c_out, ctype_out *resid_in)                                       \
+    {                                                                                                                  \
+        preload_residual_vectorized<ctype_out, DIM_M, DIM_N>(c_out, resid_in);                                        \
+    }
+
+combos(matmul_vectorized_c_func) combos(matmul_scalar_c_func) combos(zero_vectorized_c_func) combos(zero_scalar_c_func) combos(preload_residual_c_func)
 
 } // extern "C"
\ No newline at end of file
