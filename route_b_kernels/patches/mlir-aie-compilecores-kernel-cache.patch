+// -------------------------------------------------------------------------
+// Kernel-cache dedup instrumentation + structural cache key
+// -------------------------------------------------------------------------
+// Phase-time accumulators (milliseconds, summed across all per-core threads).
+// Used by the -v phase-split report (Task 1 Step 2 of the kernel-cache plan).
+// Atomic doubles via compare-exchange (no std::atomic<double> fetch_add pre-C++20
+// in a portable way; this is fine for low-contention summation).
+static std::atomic<long long> g_phaseLowerNs{0};
+static std::atomic<long long> g_phaseTranslateNs{0};
+static std::atomic<long long> g_phaseOptNs{0};
+static std::atomic<long long> g_phaseLlcNs{0};
+static std::atomic<long long> g_phaseLinkNs{0};
+static std::atomic<long long> g_phaseRenameNs{0};
+static std::atomic<int> g_coresFull{0};
+static std::atomic<int> g_coresDerived{0};
