+using Clock = std::chrono::steady_clock;
+static inline long long elapsedNs(Clock::time_point t0) {
+  return std::chrono::duration_cast<std::chrono::nanoseconds>(Clock::now() - t0)
+      .count();
+}
+
+// Mask tile-specific symbol *indices* so structurally-identical cores hash to
+// the same key. Ports the EXACT masking the validated premise used
+// ([[aiecc-kernel-cache-dedup-validated]]): replace digit-runs ONLY inside
+// @-symbol tokens, preserving bare immediates/sizes outside symbols (so a
+// folded tile-address would still show as a bare-int diff -> different key ->
+// compiled separately = safe by construction). Also normalize the
+// `core_<col>_<row>` and `_anonymousN` / `in0_N` / `out0_N` suffix indices,
+// which are all part of @-symbol names and thus already covered by the
+// inside-@-symbol digit masking.
+static std::string maskTileSymbols(llvm::StringRef s) {
+  std::string out;
+  out.reserve(s.size());
+  size_t i = 0, n = s.size();
+  auto isSymChar = [](char c) {
+    return std::isalnum((unsigned char)c) || c == '_' || c == '.' || c == '$';
+  };
+  while (i < n) {
+    char c = s[i];
+    if (c == '@' || c == '%') {
+      // Start of an LLVM symbol/value name (global @ or local %). Emit the
+      // sigil, then copy the identifier with every maximal digit-run replaced
+      // by a single 'N' placeholder. Quoted names (@"...") are handled by
+      // copying through the quotes but still masking digits inside.
+      out.push_back(c);
+      i++;
+      bool quoted = (i < n && s[i] == '"');
+      if (quoted) {
+        out.push_back(s[i]);
+        i++;
+        while (i < n && s[i] != '"') {
+          if (std::isdigit((unsigned char)s[i])) {
+            out.push_back('N');
+            while (i < n && std::isdigit((unsigned char)s[i]))
+              i++;
+          } else {
+            out.push_back(s[i]);
+            i++;
+          }
+        }
+        if (i < n && s[i] == '"') {
+          out.push_back('"');
+          i++;
+        }
+      } else {
+        while (i < n && isSymChar(s[i])) {
+          if (std::isdigit((unsigned char)s[i])) {
+            out.push_back('N');
+            while (i < n && std::isdigit((unsigned char)s[i]))
+              i++;
+          } else {
+            out.push_back(s[i]);
+            i++;
+          }
+        }
+      }
+    } else {
+      out.push_back(c);
+      i++;
+    }
+  }
+  return out;
+}
+
+// Extract the single `aie.core(%tile_C_R) { ... }` block from a per-core slice
+// module string (brace-matched). The slice has exactly ONE core (others were
+// erased), so we key/rename on the CORE BODY ONLY — NOT the whole slice. The
+// device shell (tiles/buffers/locks/objectfifos/runtime-seq) is kept identically
+// in every slice of a device but the per-core lock/anon-buffer declarations are
+// emitted ADJACENT to each core, so erasing different other-cores shifts shell
+// line POSITIONS even though the content is identical. Keying on the full slice
+// would therefore hash position noise and defeat the dedup (observed: 32 GEMM
+// tiles -> 32 "unique" instead of 1). The core body alone is position-stable and
+// fully determines the compiled .opt.ll (the body references shell symbols by
+// name, which the masking normalizes). Returns the body substring, or the whole
+// input if no core block is found (defensive -> distinct key -> full compile).
+static llvm::StringRef extractCoreBody(llvm::StringRef moduleStr) {
+  size_t anchor = moduleStr.find("aie.core(");
+  if (anchor == llvm::StringRef::npos)
+    return moduleStr;
+  // Back up to the start of the line so the `%core_C_R = ` SSA result (the core
+  // function name, which becomes @core_C_R in the .opt.ll and MUST be renamed)
+  // is included in the body substring.
+  size_t p = moduleStr.rfind('\n', anchor);
+  p = (p == llvm::StringRef::npos) ? 0 : p + 1;
+  // Find the opening brace of the core body.
+  size_t brace = moduleStr.find('{', anchor);
+  if (brace == llvm::StringRef::npos)
+    return moduleStr;
+  int depth = 0;
+  size_t i = brace;
+  for (; i < moduleStr.size(); ++i) {
+    if (moduleStr[i] == '{')
+      depth++;
+    else if (moduleStr[i] == '}') {
+      depth--;
+      if (depth == 0) {
+        ++i; // include closing brace
+        break;
+      }
+    }
+  }
+  return moduleStr.substr(p, i - p);
+}
+
+// SHA256 hex of the masked CORE BODY = the structural cache key.
+static std::string coreStructuralKey(llvm::StringRef moduleStr) {
+  std::string masked = maskTileSymbols(extractCoreBody(moduleStr));
+  llvm::SHA256 hasher;
+  hasher.update(llvm::ArrayRef<uint8_t>(
+      reinterpret_cast<const uint8_t *>(masked.data()), masked.size()));
+  return llvm::toHex(hasher.final(), /*LowerCase=*/true);
+}
+
+// True if c can appear inside an LLVM @/% identifier (unquoted form).
+static inline bool isLLVMIdentChar(char c) {
+  return std::isalnum((unsigned char)c) || c == '_' || c == '.' || c == '$';
+}
+
+// Return the substring of `moduleStr` spanning the `aie.device(...) @<name> {
+// ... }` block (brace-matched). The per-core slice keeps the WHOLE module (all
+// devices share tile coords like (0,2)), so symbol/tile scans MUST be scoped to
+// the relevant device to avoid matching another device's identically-numbered
+// tile. Returns the whole module if the device is not found (defensive).
+static llvm::StringRef deviceBlock(llvm::StringRef moduleStr,
+                                   llvm::StringRef deviceName) {
+  // Anchor on `@<deviceName> {` (the device symbol). deviceName is the bare
+  // symbol (e.g. "op1_GEMM"); the printed form is `aie.device(npu2) @op1_GEMM {`.
+  std::string anchor = "@" + deviceName.str();
+  size_t a = moduleStr.find(anchor);
+  if (a == llvm::StringRef::npos)
+    return moduleStr;
+  size_t brace = moduleStr.find('{', a);
+  if (brace == llvm::StringRef::npos)
+    return moduleStr;
+  int depth = 0;
+  size_t i = brace;
+  for (; i < moduleStr.size(); ++i) {
+    if (moduleStr[i] == '{')
+      depth++;
+    else if (moduleStr[i] == '}') {
+      depth--;
+      if (depth == 0) {
+        ++i;
+        break;
+      }
+    }
+  }
+  return moduleStr.substr(a, i - a);
+}
+
+// Enumerate, in DECLARATION ORDER, the sym_names of every aie.buffer / aie.lock
+// bound to a given tile WITHIN the named device block. These are exactly the
+// tile-specific globals that survive into the per-core .opt.ll (after DCE keeps
+// only this core's). Declaration order is identical across tiles of the same
+// kernel (same objectfifo wiring), so positionally pairing rep-tile's list with
+// target-tile's list yields the rename map.
+static void collectTileSymbols(llvm::StringRef moduleStr,
+                               llvm::StringRef deviceName, int col, int row,
+                               llvm::SmallVectorImpl<std::string> &syms) {
+  llvm::StringRef scope = deviceBlock(moduleStr, deviceName);
+  std::string tileTok = "%tile_" + std::to_string(col) + "_" +
+                        std::to_string(row);
+  llvm::SmallVector<llvm::StringRef, 0> lines;
+  scope.split(lines, '\n');
+  for (llvm::StringRef line : lines) {
+    // Match: <ws> %NAME = aie.buffer(%tile_C_R ...   OR  %NAME = aie.lock(%tile_C_R ...
+    llvm::StringRef t = line.ltrim();
+    if (!t.starts_with("%"))
+      continue;
+    size_t eq = t.find(" = aie.");
+    if (eq == llvm::StringRef::npos)
+      continue;
+    llvm::StringRef rhs = t.substr(eq + 3); // skip " = " -> points at "aie...."
+    if (!(rhs.starts_with("aie.buffer(") || rhs.starts_with("aie.lock(")))
+      continue;
+    // The tile operand must be EXACTLY this tile (tileTok followed by ',' or ')').
+    size_t tp = rhs.find(tileTok);
+    if (tp == llvm::StringRef::npos)
+      continue;
+    char after = (tp + tileTok.size() < rhs.size()) ? rhs[tp + tileTok.size()]
+                                                    : '\0';
+    if (after != ',' && after != ')')
+      continue; // avoid %tile_1_2 matching %tile_1_20
+    // Extract the LHS bare name (between % and " =").
+    llvm::StringRef name = t.substr(1, eq - 1);
+    syms.push_back(name.str());
+  }
+}
+
+// Build a bare-identifier rename map (repIdent -> targetIdent) for deriving the
+// target core's .opt.ll from the representative's. Two symbol classes:
+//   1. The core/tile names: core_<C>_<R>, tile_<C>_<R> (direct from coords).
+//   2. The per-tile buffer/lock globals: enumerated per-tile from each slice's
+//      shell (collectTileSymbols) and paired positionally. We can NOT recover
+//      these from the pre-lowering CORE BODY alone, because the body references
+//      object FIFOs generically and the concrete buffer symbol is chosen during
+//      per-(col,row) lowering — so the body text differs only in core/tile names
+//      across same-kernel tiles. The shell, however, names every buffer with its
+//      tile, so the shell is the cheap source of the concrete rename.
+// Safety: positional pairing is validated by requiring the masked forms to match
+// (maskTileSymbols(rep[i]) == maskTileSymbols(tgt[i])) and the counts to be
+// equal; any mismatch -> failure -> caller falls back to a full compile.
+static LogicalResult buildRenameMap(llvm::StringRef repModule,
+                                    llvm::StringRef tgtModule,
+                                    llvm::StringRef deviceName, int repCol,
+                                    int repRow, int tgtCol, int tgtRow,
+                                    llvm::StringMap<std::string> &renameMap) {
+  // 1. core/tile direct renames.
+  auto add = [&](const std::string &from, const std::string &to) -> bool {
+    auto it = renameMap.find(from);
+    if (it != renameMap.end())
+      return it->second == to;
+    renameMap[from] = to;
+    return true;
+  };
+  std::string repCR = std::to_string(repCol) + "_" + std::to_string(repRow);
+  std::string tgtCR = std::to_string(tgtCol) + "_" + std::to_string(tgtRow);
+  if (!add("core_" + repCR, "core_" + tgtCR))
+    return failure();
+  if (!add("tile_" + repCR, "tile_" + tgtCR))
+    return failure();
+
+  // 2. per-tile buffer/lock globals, paired positionally with masked-form check.
+  llvm::SmallVector<std::string, 32> repSyms, tgtSyms;
+  collectTileSymbols(repModule, deviceName, repCol, repRow, repSyms);
+  collectTileSymbols(tgtModule, deviceName, tgtCol, tgtRow, tgtSyms);
+  if (repSyms.size() != tgtSyms.size())
+    return failure();
+  for (size_t i = 0; i < repSyms.size(); ++i) {
+    // Structural sanity: the i-th symbol of each tile must be the same KIND
+    // (same name modulo indices), else the lists are misaligned.
+    if (maskTileSymbols("%" + repSyms[i]) != maskTileSymbols("%" + tgtSyms[i]))
+      return failure();
+    if (!add(repSyms[i], tgtSyms[i]))
+      return failure();
+  }
+  return success();
+}
+
+// Apply a bare-identifier rename map to one line of LLVM IR, renaming whole
+// @<ident> / %<ident> identifier tokens only (never substrings, never literals).
+static std::string applyRenameToLine(llvm::StringRef line,
+                                     const llvm::StringMap<std::string> &m) {
+  std::string out;
+  out.reserve(line.size() + 16);
+  size_t i = 0, n = line.size();
+  while (i < n) {
+    char c = line[i];
+    if (c == '@' || c == '%') {
+      // Quoted identifiers: leave as-is (rare; our tile symbols are unquoted).
+      if (i + 1 < n && line[i + 1] == '"') {
+        out.push_back(c);
+        i++;
+        continue;
+      }
+      size_t start = i + 1;
+      size_t j = start;
+      while (j < n && isLLVMIdentChar(line[j]))
+        j++;
+      llvm::StringRef ident = line.substr(start, j - start);
+      auto it = m.find(ident);
+      out.push_back(c);
+      if (it != m.end())
+        out.append(it->second);
+      else
+        out.append(ident.str());
+      i = j;
+    } else {
+      out.push_back(c);
+      i++;
+    }
+  }
+  return out;
+}
+
+// Generate the per-core linker script from the PRE-LOWERING module (the slice).
+// Factored out of compileCore so the kernel-cache derive path (deriveCore) and
+// the full-compile path share ONE ld.script code path (byte-identical link).
+static LogicalResult genLdScriptForCore(ModuleOp moduleOp, StringRef deviceName,
+                                        const CoreInfo &core,
+                                        StringRef tmpDirName,
+                                        StringRef ldScriptPath) {
+  // Clone the pre-lowering module for ldscript generation. We cannot mutate the
+  // shared moduleOp (data race with parallel core threads), so this per-thread
+  // clone is the correct place to rewrite link_files to absolute paths.
+  OwningOpRef<ModuleOp> ldScriptModule = moduleOp.clone();
+  ldScriptModule->walk([&](xilinx::AIE::CoreOp coreOp) {
+    auto tileOp = dyn_cast<xilinx::AIE::TileOp>(coreOp.getTile().getDefiningOp());
+    if (!tileOp || tileOp.getCol() != core.col || tileOp.getRow() != core.row)
+      return;
+    if (auto filesAttr = coreOp.getLinkFiles()) {
+      SmallVector<mlir::Attribute> absFiles;
+      for (auto f : filesAttr->getAsRange<mlir::StringAttr>()) {
+        SmallString<256> absPath(tmpDirName);
+        sys::path::append(absPath, sys::path::filename(f.getValue()));
+        absFiles.push_back(
+            mlir::StringAttr::get(ldScriptModule->getContext(), absPath));
+      }
+      coreOp.setLinkFilesAttr(
+          mlir::ArrayAttr::get(ldScriptModule->getContext(), absFiles));
+    }
+  });
+
+  std::error_code ec;
+  raw_fd_ostream ldScriptFile(ldScriptPath, ec);
+  if (ec) {
+    std::lock_guard<std::mutex> lock(outputMutex);
+    llvm::errs() << "Error opening linker script file: " << ec.message() << "\n";
+    return failure();
+  }
+  if (failed(xilinx::AIE::AIETranslateToLdScript(
+          *ldScriptModule, ldScriptFile, core.col, core.row, deviceName))) {
+    std::lock_guard<std::mutex> lock(outputMutex);
+    llvm::errs() << "Error generating linker script\n";
+    return failure();
+  }
+  if (verbose) {
+    std::lock_guard<std::mutex> lock(outputMutex);
+    llvm::outs() << "Generated linker script: " << ldScriptPath << "\n";
+  }
+  return success();
+}
+
+// Peano back-end: llc (.opt.ll -> .o) then clang link (.o + ld.script -> .elf).
+// Extracted from compileCore so the full-compile and kernel-cache derive paths
+// share ONE byte-identical llc+link code path (the byte gate's correctness
+// fulcrum). Only the Peano / --no-xbridge path is supported here.
+static LogicalResult peanoLlcAndLink(StringRef optPath, StringRef objPath,
+                                     StringRef ldScriptPath, StringRef elfPath,
+                                     StringRef deviceName, const CoreInfo &core,
+                                     StringRef aieTarget, StringRef tmpDirName) {
+  std::string peanoLlc = findPeanoTool("llc");
+  if (peanoLlc.empty()) {
+    std::lock_guard<std::mutex> lock(outputMutex);
+    llvm::errs() << "Error: Could not find Peano llc\n";
+    return failure();
+  }
+  std::string optLevelStr = std::to_string(optLevel);
+
+  // Run llc
+  SmallVector<std::string, 10> llcCmd = {peanoLlc,
+                                         std::string(optPath),
+                                         "-O" + optLevelStr,
+                                         "--march=" + aieTarget.lower(),
+                                         "--function-sections",
+                                         "--filetype=obj",
+                                         "-o",
+                                         std::string(objPath)};
+  auto tLlc0 = Clock::now();
+  if (!executeCommand(llcCmd)) {
+    std::lock_guard<std::mutex> lock(outputMutex);
+    llvm::errs() << "Error running Peano llc\n";
+    return failure();
+  }
+  g_phaseLlcNs += elapsedNs(tLlc0);
+
+  // Link with Peano clang
+  std::string peanoClang = findPeanoTool("clang");
+  if (peanoClang.empty()) {
+    std::lock_guard<std::mutex> lock(outputMutex);
+    llvm::errs() << "Error: Could not find Peano clang\n";
+    return failure();
+  }
+
+  std::string peanoTarget = getPeanoTarget(aieTarget);
+
+  // Get Peano bin directory for the linker
+  StringRef peanoDir = getPeanoInstallDir();
+  SmallString<128> peanoBinDir;
+  if (!peanoDir.empty()) {
+    peanoBinDir = peanoDir;
+    sys::path::append(peanoBinDir, "bin");
+  } else {
+    peanoBinDir = sys::path::parent_path(peanoClang);
+  }
+
+  // Find Peano's lld linker explicitly
+  SmallString<256> peanoLld(peanoBinDir);
+  sys::path::append(peanoLld, "ld.lld");
+
+  SmallVector<std::string, 20> linkCmd = {peanoClang, "-O" + optLevelStr,
+                                          "--target=" + peanoTarget};
+
+  if (sys::fs::can_execute(peanoLld)) {
+    linkCmd.push_back("-fuse-ld=" + std::string(peanoLld));
+  } else {
+    linkCmd.push_back("-B" + std::string(peanoBinDir));
+    linkCmd.push_back("-fuse-ld=lld");
+  }
+
+  linkCmd.push_back(std::string(objPath));
+
+  // Handle external object files specified via link_files (or deprecated
+  // link_with). The linker script has INPUT() directives (relative paths); copy
+  // every file to the .prj directory so the linker can find them.
+  for (const auto &lf : core.linkFiles) {
+    SmallString<256> srcLinkWith;
+    if (sys::path::is_absolute(lf)) {
+      srcLinkWith = lf;
+    } else {
+      SmallString<256> cwdPath;
+      sys::fs::current_path(cwdPath);
+      sys::path::append(cwdPath, lf);
+      if (sys::fs::exists(cwdPath)) {
+        srcLinkWith = cwdPath;
+      } else {
+        SmallString<256> tmpPath(tmpDirName);
+        sys::path::append(tmpPath, lf);
+        if (sys::fs::exists(tmpPath)) {
+          srcLinkWith = tmpPath;
+        } else {
+          SmallString<256> inputDir =
+              sys::path::parent_path(getInputFilename());
+          if (inputDir.empty())
+            sys::fs::current_path(inputDir);
+          srcLinkWith = inputDir;
+          sys::path::append(srcLinkWith, lf);
+          sys::path::remove_dots(srcLinkWith, /*remove_dot_dot=*/true);
+        }
+      }
+    }
+
+    SmallString<256> destLinkWith(tmpDirName);
+    sys::path::append(destLinkWith, sys::path::filename(lf));
+    if (srcLinkWith != destLinkWith) {
+      if (failed(atomicCopyFile(srcLinkWith, tmpDirName,
+                                sys::path::filename(lf))))
+        return failure();
+      if (verbose) {
+        std::lock_guard<std::mutex> lock(outputMutex);
+        llvm::outs() << "Copied external object: " << srcLinkWith << " -> "
+                     << destLinkWith << "\n";
+      }
+    } else if (verbose) {
+      std::lock_guard<std::mutex> lock(outputMutex);
+      llvm::outs() << "External object already in place: " << srcLinkWith
+                   << "\n";
+    }
+    // The .o is not added to linkCmd — the linker script INPUT()s it.
+  }
+
+  // Make linker script path absolute
+  SmallString<128> absLdScriptPath;
+  if (sys::path::is_absolute(ldScriptPath)) {
+    absLdScriptPath = ldScriptPath;
+  } else {
+    std::error_code ec = sys::fs::real_path(ldScriptPath, absLdScriptPath);
+    if (ec) {
+      sys::fs::current_path(absLdScriptPath);
+      sys::path::append(absLdScriptPath, ldScriptPath);
+    }
+  }
+
+  linkCmd.push_back("-Wl,--gc-sections");
+  linkCmd.push_back("-Wl,--orphan-handling=error");
+  linkCmd.push_back("-Wl,-T," + std::string(absLdScriptPath));
+
+  if (linkAgainstHsa) {
+    if (!sysroot.empty()) {
+      SmallString<256> rocmLibPath(sysroot);
+      sys::path::append(rocmLibPath, "opt", "rocm", "lib");
+      linkCmd.push_back("-L" + std::string(rocmLibPath));
+    } else {
+      linkCmd.push_back("-L/opt/rocm/lib");
+    }
+    linkCmd.push_back("-lhsa-runtime64");
+  }
+
+  linkCmd.push_back("-o");
+  linkCmd.push_back(std::string(elfPath));
+
+  auto tLink0 = Clock::now();
+  if (!executeCommand(linkCmd)) {
+    std::lock_guard<std::mutex> lock(outputMutex);
+    llvm::errs() << "Error linking ELF file\n";
+    return failure();
+  }
+  g_phaseLinkNs += elapsedNs(tLink0);
+  return success();
+}
