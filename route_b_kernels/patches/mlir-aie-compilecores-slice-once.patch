+  std::map<std::pair<int, int>, std::string> coreModuleStrs;
+  for (const auto &core : cores) {
+    OwningOpRef<ModuleOp> slice = moduleOp.clone();
+    SmallVector<xilinx::AIE::CoreOp> otherCores;
