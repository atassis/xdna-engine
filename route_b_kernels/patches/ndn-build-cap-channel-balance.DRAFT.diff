 class DMAChannelAnalysis {
   DenseMap<std::tuple<Value, DMAChannelDir, int>, int> channelsPerTile;
   DenseMap<std::tuple<Value, DMAChannelDir, int>, int> aieStreamsPerTile;
+  // DRAFT (ndn-build-cap, internal notes): a MemTile's BD-ID
+  // namespace is split into two 24-wide halves by channel-number PARITY (see
+  // AIETargetModel::isBdChannelAccessible: even channel -> bd_id<24, odd channel -> bd_id
+  // >=24), shared across ALL channels of that parity -- NOT exclusive per channel index. A
+  // pure first-fit-by-index channel assignment can pack multiple relays onto the same
+  // parity and starve the BD allocator well below the combined 48-ID budget even though
+  // distinct channel *indices* look "free". Track cumulative depth charged per (tile,
+  // parity) so getDMAChannelIndex can prefer the less-loaded parity when a depth hint is
+  // available. UNVERIFIED -- needs an attended build-check (see the handoff for the repro).
+  DenseMap<std::pair<Value, int>, int> bdLoadPerParity;
+
+  int bdLoad(TileOp tileOp, int parity) {
+    return bdLoadPerParity.lookup({tileOp.getResult(), parity});
+  }
+  void chargeBdLoad(TileOp tileOp, int parity, int depth) {
+    bdLoadPerParity[{tileOp.getResult(), parity}] += depth;
+  }
 
