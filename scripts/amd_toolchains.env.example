# AMD-toolchain target repo paths for scripts/setup_amd_toolchains.sh.
#
# Copy to `scripts/amd_toolchains.env` (gitignored) and adjust. This keeps absolute
# fork/checkout paths OUT of git -- the committed scripts only read these vars.
#
#   cp scripts/amd_toolchains.env.example scripts/amd_toolchains.env
#
# Defaults are auto-derived by scripts/amd_paths.sh from the workspace root
# ($XDNA_WS = parent of this engine repo): IRON_DIR/XRT_SRC_DIR/AIEBU_ASM_DIR all
# resolve to $XDNA_WS/amd/<repo> with NO hardcoded $HOME path. Override here only to
# point somewhere else. mlir-aie is the in-repo submodule by default (no var needed).

# IRON_DIR="${XDNA_WS}/amd/IRON"                        # default (auto): the IRON operator-library checkout
# XRT_SRC_DIR="${XDNA_WS}/amd/XRT-src"                  # default (auto): XRT source (aiebu-asm lives under it)
# MLIR_AIE_DIR="<repo>/mlir-aie"                        # default: the vendored submodule
# LLVM_AIE_DIR="${XDNA_WS}/amd/llvm-aie"               # empty by default = do NOT patch Peano; set to opt in
# MLIR_AIR_DIR="${XDNA_WS}/amd/mlir-air"               # empty by default = do NOT patch mlir-air; set to opt in
