# AMD-toolchain target repo paths for scripts/setup_amd_toolchains.sh.
#
# Copy to `scripts/amd_toolchains.env` (gitignored) and adjust. This keeps absolute
# fork/checkout paths OUT of git -- the committed scripts only read these vars.
#
#   cp scripts/amd_toolchains.env.example scripts/amd_toolchains.env
#
# mlir-aie is the in-repo submodule by default (no var needed); override only if
# you point at an external checkout.

# IRON_DIR="${HOME}/repositories/ns/amd/IRON"
# MLIR_AIE_DIR="<repo>/mlir-aie"          # default: the vendored submodule
# LLVM_AIE_DIR="${HOME}/repositories/ns/amd/llvm-aie"   # set when patching Peano
# MLIR_AIR_DIR="${HOME}/repositories/ns/amd/mlir-air"   # set when patching mlir-air
