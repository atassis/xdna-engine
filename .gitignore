# python
.venv/
.venv-iron/
__pycache__/
*.pyc
# NOTE: mlir-aie/ is a pinned git submodule. Its dirty working tree (copy-forward
# kernels + build artifacts + applied patch) is hidden from the parent via
# .gitmodules ignore=all.

# model artifacts / weights (too big to commit — keep export scripts + instructions instead)
models/
# artifacts/ is regenerable: scripts/extract_block0.py + extract_blocks.py from the ONNX
artifacts/
*.onnx
*.xclbin
*.bin
*.safetensors
*.nemo

# scratch
*.wav
*.log

# rust build artifacts
rust/target/
build/
route_b_kernels/decode_fused/build/
**/build/

# local AMD-toolchain target paths (no absolute fork paths in git)
scripts/amd_toolchains.env

# stray aircc output if a build is ever run with CWD=repo-root (real output goes to artifacts/)
/air.mlir
/air_project/

# agent scaffolding and the private companion working copy must never be tracked here
.claude/
journal/
strategy/
STARTER_PROMPT*.md
